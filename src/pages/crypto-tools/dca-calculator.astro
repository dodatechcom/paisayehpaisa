---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="DCA Calculator" description="See how dollar-cost averaging grows your crypto investment over time. Free calculator.">
  <meta name="robots" content="noindex" />

  <div style="max-width: 600px; margin: 0 auto; padding: 2rem 0;">
    <div class="cat-header" style="margin-bottom: 0.5rem;">
      <span class="icon">🛠️</span>
      <h1 style="margin:0; font-size:1.8rem;">DCA Calculator</h1>
    </div>
    <p style="color:var(--muted); margin-bottom:2rem;">See how regular investing adds up over time.</p>

    <div id="dca-app" style="background:var(--surface); padding:1.5rem; border-radius:var(--radius); box-shadow:var(--shadow);">
      <div style="display:grid; gap:1rem; margin-bottom:1.5rem;">
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Monthly Investment ($)</label>
          <input type="number" id="amount" value="100" min="1" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Duration (months)</label>
          <input type="number" id="months" value="12" min="1" max="600" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Expected Annual Return (%)</label>
          <input type="number" id="return" value="10" min="0" max="500" step="0.5" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Current BTC Price ($)</label>
          <input type="number" id="btc-price" value="60000" min="1" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
      </div>

      <button id="calc-btn" style="width:100%; padding:0.75rem; background:var(--accent); color:white; border:none; border-radius:8px; font-size:1rem; font-weight:600; cursor:pointer;">Calculate</button>

      <div id="results" style="display:none; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Total Invested</div>
            <div id="total-invested" style="font-size:1.3rem; font-weight:700; color:var(--text);">$0</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Total Value</div>
            <div id="total-value" style="font-size:1.3rem; font-weight:700; color:var(--text);">$0</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">BTC Accumulated</div>
            <div id="total-btc" style="font-size:1.3rem; font-weight:700; color:var(--text);">0 BTC</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Profit / Loss</div>
            <div id="profit" style="font-size:1.3rem; font-weight:700;">$0</div>
          </div>
        </div>
      </div>
    </div>

    <div style="margin-top:2rem; background:var(--surface); padding:1.25rem; border-radius:var(--radius); box-shadow:var(--shadow); font-size:0.88rem; color:var(--muted);">
      <strong style="color:var(--text);">How it works:</strong> This calculator assumes a fixed monthly investment and a conservative annual return. Past performance doesn't guarantee future results. DCA reduces risk from market timing but doesn't guarantee profit.
    </div>
  </div>

  <script>
    document.getElementById('calc-btn').addEventListener('click', function() {
      const amount = parseFloat(document.getElementById('amount').value) || 0;
      const months = parseInt(document.getElementById('months').value) || 0;
      const annualReturn = parseFloat(document.getElementById('return').value) || 0;
      const btcPrice = parseFloat(document.getElementById('btc-price').value) || 1;

      const monthlyReturn = Math.pow(1 + annualReturn / 100, 1 / 12) - 1;

      let totalInvested = 0;
      let totalBtc = 0;

      for (let m = 0; m < months; m++) {
        const btcBought = amount / btcPrice;
        totalBtc += btcBought;
        totalInvested += amount;
      }

      let totalValue = 0;
      for (let m = 0; m < months; m++) {
        const monthsGrown = months - m;
        const btcAtMonth = amount / btcPrice;
        const grownValue = btcAtMonth * btcPrice * Math.pow(1 + monthlyReturn, monthsGrown);
        totalValue += grownValue;
      }

      const profit = totalValue - totalInvested;

      document.getElementById('total-invested').textContent = '$' + totalInvested.toLocaleString('en-US', { maximumFractionDigits: 0 });
      document.getElementById('total-value').textContent = '$' + totalValue.toLocaleString('en-US', { maximumFractionDigits: 0 });
      document.getElementById('total-btc').textContent = totalBtc.toFixed(6) + ' BTC';
      const profitEl = document.getElementById('profit');
      profitEl.textContent = (profit >= 0 ? '+' : '') + '$' + profit.toLocaleString('en-US', { maximumFractionDigits: 0 });
      profitEl.style.color = profit >= 0 ? '#16a34a' : '#dc2626';

      document.getElementById('results').style.display = 'block';
    });

    document.getElementById('calc-btn').click();
  </script>
</BaseLayout>
