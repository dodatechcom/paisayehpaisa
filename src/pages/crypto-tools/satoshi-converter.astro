---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Satoshi Converter" description="Convert between Bitcoin (BTC), satoshis, US dollars, and Indian rupees instantly. Free BTC converter tool.">
  <meta name="robots" content="noindex" />
  <div style="max-width: 600px; margin: 0 auto; padding: 2rem 0;">
    <div class="cat-header" style="margin-bottom: 0.5rem;">
      <span class="icon">🪙</span>
      <h1 style="margin:0; font-size:1.8rem;">Satoshi Converter</h1>
    </div>
    <p style="color:var(--muted); margin-bottom:2rem;">Convert between BTC, satoshis, USD, and INR instantly.</p>

    <div style="background:var(--surface); padding:1.5rem; border-radius:var(--radius); box-shadow:var(--shadow);">
      <div style="display:grid; gap:1rem; margin-bottom:1.5rem;">
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">BTC Price ($)</label>
          <input type="number" id="btc-price" value="65000" min="1" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">USD to INR Rate</label>
          <input type="number" id="usd-inr" value="83" min="1" step="0.01" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:1rem;">
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">BTC</label>
          <input type="number" id="btc" value="0.005" min="0" step="any" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Satoshis</label>
          <input type="number" id="sats" value="500000" min="0" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">USD ($)</label>
          <input type="number" id="usd" value="325" min="0" step="any" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">INR (₹)</label>
          <input type="number" id="inr" value="26975" min="0" step="any" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
      </div>

      <div style="font-size:0.82rem; color:var(--muted); text-align:center;">
        Edit any field — all others update automatically.
      </div>
    </div>
  </div>

  <script>
    function convertAll(changedId) {
      const btcPrice = parseFloat(document.getElementById('btc-price').value) || 0;
      const usdInr = parseFloat(document.getElementById('usd-inr').value) || 0;

      const fields = ['btc', 'sats', 'usd', 'inr'];

      if (changedId === 'btc') {
        const btc = parseFloat(document.getElementById('btc').value) || 0;
        const sats = btc * 100000000;
        const usd = btc * btcPrice;
        const inr = usd * usdInr;
        document.getElementById('sats').value = Math.round(sats);
        document.getElementById('usd').value = usd.toFixed(2);
        document.getElementById('inr').value = inr.toFixed(2);
      } else if (changedId === 'sats') {
        const sats = parseFloat(document.getElementById('sats').value) || 0;
        const btc = sats / 100000000;
        const usd = btc * btcPrice;
        const inr = usd * usdInr;
        document.getElementById('btc').value = btc.toFixed(8);
        document.getElementById('usd').value = usd.toFixed(2);
        document.getElementById('inr').value = inr.toFixed(2);
      } else if (changedId === 'usd') {
        const usd = parseFloat(document.getElementById('usd').value) || 0;
        const btc = btcPrice > 0 ? usd / btcPrice : 0;
        const sats = btc * 100000000;
        const inr = usd * usdInr;
        document.getElementById('btc').value = btc.toFixed(8);
        document.getElementById('sats').value = Math.round(sats);
        document.getElementById('inr').value = inr.toFixed(2);
      } else if (changedId === 'inr') {
        const inr = parseFloat(document.getElementById('inr').value) || 0;
        const usd = usdInr > 0 ? inr / usdInr : 0;
        const btc = btcPrice > 0 ? usd / btcPrice : 0;
        const sats = btc * 100000000;
        document.getElementById('usd').value = usd.toFixed(2);
        document.getElementById('btc').value = btc.toFixed(8);
        document.getElementById('sats').value = Math.round(sats);
      }
    }

    ['btc-price', 'usd-inr'].forEach(id => {
      document.getElementById(id).addEventListener('input', () => convertAll('usd'));
    });
    ['btc', 'sats', 'usd', 'inr'].forEach(id => {
      document.getElementById(id).addEventListener('input', () => convertAll(id));
    });

    convertAll('usd');
  </script>
</BaseLayout>
