---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Position Size Calculator" description="Calculate the right position size for any trade based on account size, risk percentage, and stop loss distance. Free tool for crypto and forex traders.">
  <meta name="robots" content="noindex" />
  <div style="max-width: 600px; margin: 0 auto; padding: 2rem 0;">
    <div class="cat-header" style="margin-bottom: 0.5rem;">
      <span class="icon">🎯</span>
      <h1 style="margin:0; font-size:1.8rem;">Position Size Calculator</h1>
    </div>
    <p style="color:var(--muted); margin-bottom:2rem;">Calculate how much to invest per trade based on your risk tolerance.</p>

    <div style="background:var(--surface); padding:1.5rem; border-radius:var(--radius); box-shadow:var(--shadow);">
      <div style="display:grid; gap:1rem; margin-bottom:1.5rem;">
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Account Size ($)</label>
          <input type="number" id="account" value="10000" min="1" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Risk Per Trade (%)</label>
          <input type="number" id="risk-pct" value="2" min="0.1" max="100" step="0.1" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Stop Loss Distance (%)</label>
          <input type="number" id="stop-pct" value="5" min="0.1" max="100" step="0.1" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
      </div>
      <button id="calc-btn" style="width:100%; padding:0.75rem; background:var(--accent); color:white; border:none; border-radius:8px; font-size:1rem; font-weight:600; cursor:pointer;">Calculate Position Size</button>

      <div id="results" style="display:none; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Risk Amount ($)</div>
            <div id="risk-amount" style="font-size:1.3rem; font-weight:700; color:#dc2626;">$0</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Position Size ($)</div>
            <div id="position-size" style="font-size:1.3rem; font-weight:700; color:var(--text);">$0</div>
          </div>
        </div>
      </div>
    </div>

    <div style="margin-top:2rem; background:var(--surface); padding:1.25rem; border-radius:var(--radius); box-shadow:var(--shadow); font-size:0.88rem; color:var(--muted);">
      <strong style="color:var(--text);">How it works:</strong> The 1–2% rule is a common risk management guideline. If your account is $10,000 and you risk 2% per trade with a 5% stop loss, your position size would be $4,000. This means if the trade hits your stop, you lose $200 (2% of your account).
    </div>
  </div>

  <script>
    document.getElementById('calc-btn').addEventListener('click', function() {
      const account = parseFloat(document.getElementById('account').value) || 0;
      const riskPct = parseFloat(document.getElementById('risk-pct').value) || 0;
      const stopPct = parseFloat(document.getElementById('stop-pct').value) || 1;

      const riskAmount = account * (riskPct / 100);
      const positionSize = riskAmount / (stopPct / 100);

      document.getElementById('risk-amount').textContent = '$' + riskAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      document.getElementById('position-size').textContent = '$' + positionSize.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      document.getElementById('results').style.display = 'block';
    });
    document.getElementById('calc-btn').click();
  </script>
</BaseLayout>
