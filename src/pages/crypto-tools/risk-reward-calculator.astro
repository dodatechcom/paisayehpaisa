---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Risk Reward Ratio Calculator" description="Calculate the risk/reward ratio for any trade. Enter entry price, stop loss, and take profit to evaluate your trade setup.">
  <meta name="robots" content="noindex" />
  <div style="max-width: 600px; margin: 0 auto; padding: 2rem 0;">
    <div class="cat-header" style="margin-bottom: 0.5rem;">
      <span class="icon">⚖️</span>
      <h1 style="margin:0; font-size:1.8rem;">Risk/Reward Calculator</h1>
    </div>
    <p style="color:var(--muted); margin-bottom:2rem;">Evaluate the risk/reward ratio of any trade setup.</p>

    <div style="background:var(--surface); padding:1.5rem; border-radius:var(--radius); box-shadow:var(--shadow);">
      <div style="display:grid; gap:1rem; margin-bottom:1.5rem;">
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Trade Direction</label>
          <select id="direction" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);">
            <option value="long">Long (Buy)</option>
            <option value="short">Short (Sell)</option>
          </select>
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Entry Price ($)</label>
          <input type="number" id="entry" value="100" min="0.0001" step="any" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Stop Loss ($)</label>
          <input type="number" id="stop" value="95" min="0.0001" step="any" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
        <div>
          <label style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.3rem; color:var(--text);">Take Profit ($)</label>
          <input type="number" id="target" value="120" min="0.0001" step="any" style="width:100%; padding:0.6rem 0.8rem; border:1px solid var(--border); border-radius:8px; font-size:1rem; background:var(--bg); color:var(--text);" />
        </div>
      </div>
      <button id="calc-btn" style="width:100%; padding:0.75rem; background:var(--accent); color:white; border:none; border-radius:8px; font-size:1rem; font-weight:600; cursor:pointer;">Calculate</button>

      <div id="results" style="display:none; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
        <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center; margin-bottom:0.75rem;">
          <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Risk / Reward Ratio</div>
          <div id="rr" style="font-size:2rem; font-weight:800; color:var(--text);">1:0</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Risk per Unit</div>
            <div id="risk-unit" style="font-size:1.1rem; font-weight:700; color:#dc2626;">$0</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Reward per Unit</div>
            <div id="reward-unit" style="font-size:1.1rem; font-weight:700; color:#16a34a;">$0</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Risk (%)</div>
            <div id="risk-pct" style="font-size:1.1rem; font-weight:700; color:#dc2626;">0%</div>
          </div>
          <div style="background:var(--bg); padding:1rem; border-radius:8px; text-align:center;">
            <div style="font-size:0.8rem; color:var(--muted); margin-bottom:0.25rem;">Reward (%)</div>
            <div id="reward-pct" style="font-size:1.1rem; font-weight:700; color:#16a34a;">0%</div>
          </div>
        </div>
      </div>
    </div>

    <div style="margin-top:2rem; background:var(--surface); padding:1.25rem; border-radius:var(--radius); box-shadow:var(--shadow); font-size:0.88rem; color:var(--muted);">
      <strong style="color:var(--text);">How it works:</strong> A risk/reward ratio of 1:3 means you're risking $1 to potentially make $3. Many professional traders aim for a minimum 1:2 or 1:3 ratio on every trade. Even with a 50% win rate, a 1:3 R/R ratio is highly profitable.
    </div>
  </div>

  <script>
    document.getElementById('calc-btn').addEventListener('click', function() {
      const direction = document.getElementById('direction').value;
      const entry = parseFloat(document.getElementById('entry').value) || 0;
      const stop = parseFloat(document.getElementById('stop').value) || 0;
      const target = parseFloat(document.getElementById('target').value) || 0;

      let risk, reward;
      if (direction === 'long') {
        risk = entry - stop;
        reward = target - entry;
      } else {
        risk = stop - entry;
        reward = entry - target;
      }

      const ratio = risk > 0 ? (reward / risk) : 0;
      const riskPct = entry > 0 ? (risk / entry) * 100 : 0;
      const rewardPct = entry > 0 ? (reward / entry) * 100 : 0;

      document.getElementById('rr').textContent = '1:' + ratio.toFixed(2);
      document.getElementById('rr').style.color = ratio >= 2 ? '#16a34a' : ratio >= 1 ? '#d97706' : '#dc2626';
      document.getElementById('risk-unit').textContent = '$' + Math.abs(risk).toFixed(2);
      document.getElementById('reward-unit').textContent = '$' + Math.abs(reward).toFixed(2);
      document.getElementById('risk-pct').textContent = Math.abs(riskPct).toFixed(2) + '%';
      document.getElementById('reward-pct').textContent = Math.abs(rewardPct).toFixed(2) + '%';
      document.getElementById('results').style.display = 'block';
    });
    document.getElementById('calc-btn').click();
  </script>
</BaseLayout>
