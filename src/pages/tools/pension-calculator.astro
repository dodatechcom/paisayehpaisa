---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Pension Calculator — How Much Do You Need?" description="Calculate your pension projections, see the impact of employer matching, and find out if you're on track for the retirement income you want.">
  <div class="tool-container">
    <div class="tool-header">
      <h1>Pension Calculator</h1>
      <p class="subtitle">How much do you need? — project your pension and find out if you're on track</p>
    </div>

    <div class="calculator-grid">
      <div class="input-section">
        <h2>Your Details</h2>

        <div class="input-group">
          <label for="currentAge">Current Age</label>
          <input type="number" id="currentAge" value="30" min="18" max="80" step="1">
        </div>

        <div class="input-group">
          <label for="retireAge">Retirement Age</label>
          <input type="number" id="retireAge" value="65" min="30" max="100" step="1">
        </div>

        <div class="input-group">
          <label for="currentValue">Current Pension Value</label>
          <div class="input-wrapper">
            <span class="currency">£</span>
            <input type="number" id="currentValue" value="50000" min="0" step="1000">
          </div>
        </div>

        <div class="input-group">
          <label for="monthlyContrib">Monthly Contribution (You)</label>
          <div class="input-wrapper">
            <span class="currency">£</span>
            <input type="number" id="monthlyContrib" value="300" min="0" step="25">
          </div>
        </div>

        <div class="input-group">
          <label for="employerPct">Employer Contribution (%)</label>
          <div class="input-wrapper">
            <input type="number" id="employerPct" value="5" min="0" max="100" step="0.5">
            <span class="currency">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="growthRate">Annual Growth Rate (%)</label>
          <div class="input-wrapper">
            <input type="number" id="growthRate" value="7" min="0" max="20" step="0.5">
            <span class="currency">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="desiredIncome">Desired Annual Retirement Income</label>
          <div class="input-wrapper">
            <span class="currency">£</span>
            <input type="number" id="desiredIncome" value="30000" min="0" step="1000">
          </div>
        </div>

        <button id="calculate" class="btn-primary">Calculate Pension</button>
      </div>

      <div class="results-section">
        <h2>Your Pension Projection</h2>

        <div class="results-grid">
          <div class="result-card green">
            <div class="result-label">Projected Pension Pot</div>
            <div class="result-value" id="projectedPot">£0</div>
            <div class="result-detail" id="potDetail">At retirement</div>
          </div>

          <div class="result-card blue">
            <div class="result-label">Monthly Retirement Income</div>
            <div class="result-value" id="monthlyIncome">£0</div>
            <div class="result-detail" id="incomeDetail">Based on 4% rule</div>
          </div>

          <div class="result-card yellow">
            <div class="result-label">Years of Income</div>
            <div class="result-value" id="yearsIncome">0</div>
            <div class="result-detail" id="yearsDetail">From your pension pot</div>
          </div>

          <div class="result-card" id="shortfallCard">
            <div class="result-label" id="shortfallLabel">Shortfall / Surplus</div>
            <div class="result-value" id="shortfallValue">£0</div>
            <div class="result-detail" id="shortfallDetail">Per year vs desired</div>
          </div>
        </div>

        <div class="breakdown-section">
          <h3>Pension Breakdown</h3>
          <div class="breakdown-bar" id="breakdownBar"></div>
          <div class="breakdown-legend" id="breakdownLegend"></div>
        </div>

        <div class="comparison-section">
          <h3>Employer Matching Impact</h3>
          <div class="comparison-table" id="comparisonTable"></div>
        </div>

        <div class="boost-section">
          <h3>Impact of Adding £50/month</h3>
          <div class="boost-table" id="boostTable"></div>
        </div>

        <div class="projection-section">
          <h3>Growth Over Time</h3>
          <div class="projection-bars" id="projectionBars"></div>
        </div>
      </div>
    </div>

    <div class="callout">
      <p>This calculator uses the 4% safe withdrawal rule as a guideline. Actual retirement income will depend on investment performance, inflation, tax, and how long you live. Consider consulting a financial adviser for personalised planning.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .tool-container {
    --bg: #0f172a;
    --surface: #1e293b;
    --surface-alt: #1a1d23;
    --text: #e2e8f0;
    --muted: #94a3b8;
    --border: #334155;
    --green: #22c55e;
    --blue: #3b82f6;
    --yellow: #f59e0b;
    --red: #ef4444;
    --purple: #a855f7;

    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .tool-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .tool-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .subtitle {
    color: var(--muted);
    font-size: 1rem;
  }

  .calculator-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .calculator-grid {
      grid-template-columns: 1fr;
    }
  }

  .input-section, .results-section {
    background: var(--surface);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .input-section h2, .results-section h2 {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .input-group {
    margin-bottom: 1rem;
  }

  .input-group label {
    display: block;
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .currency {
    padding: 0 0.75rem;
    color: var(--green);
    font-weight: 600;
    font-size: 0.875rem;
  }

  input[type="number"] {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text);
    padding: 0.75rem;
    font-size: 1rem;
    font-family: inherit;
    width: 100%;
  }

  input[type="number"]:focus {
    outline: none;
  }

  .input-group:has(.input-wrapper) input[type="number"] {
    padding-left: 0;
  }

  .btn-primary {
    width: 100%;
    padding: 0.875rem;
    background: linear-gradient(135deg, var(--green), #16a34a);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }

  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 500px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  .result-card {
    background: var(--surface-alt);
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
    border-left: 3px solid;
    border-color: var(--border);
  }

  .result-card.green { border-color: var(--green); }
  .result-card.blue { border-color: var(--blue); }
  .result-card.yellow { border-color: var(--yellow); }
  .result-card.red { border-color: var(--red); }
  .result-card.purple { border-color: var(--purple); }

  .result-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .result-card.green .result-value { color: var(--green); }
  .result-card.blue .result-value { color: var(--blue); }
  .result-card.yellow .result-value { color: var(--yellow); }
  .result-card.red .result-value { color: var(--red); }
  .result-card.purple .result-value { color: var(--purple); }

  .result-detail {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .breakdown-section,
  .comparison-section,
  .boost-section,
  .projection-section {
    margin-bottom: 1.5rem;
  }

  .breakdown-section h3,
  .comparison-section h3,
  .boost-section h3,
  .projection-section h3 {
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .breakdown-bar {
    height: 32px;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    margin-bottom: 0.75rem;
  }

  .breakdown-bar .segment {
    height: 100%;
    transition: width 0.5s ease;
    position: relative;
  }

  .breakdown-bar .seg-current { background: var(--blue); }
  .breakdown-bar .seg-contrib { background: var(--green); }
  .breakdown-bar .seg-growth { background: var(--purple); }

  .breakdown-legend {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .breakdown-legend .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .breakdown-legend .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
  }

  .comparison-table,
  .boost-table {
    background: var(--surface-alt);
    border-radius: 8px;
    overflow: hidden;
  }

  .comparison-table .row,
  .boost-table .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.875rem;
  }

  .comparison-table .row:last-child,
  .boost-table .row:last-child {
    border-bottom: none;
  }

  .comparison-table .row .label,
  .boost-table .row .label {
    color: var(--muted);
  }

  .comparison-table .row .value,
  .boost-table .row .value {
    color: var(--text);
    font-weight: 600;
  }

  .comparison-table .row .value.positive { color: var(--green); }
  .comparison-table .row .value.negative { color: var(--red); }
  .boost-table .row .value.positive { color: var(--green); }

  .comparison-table .row.header,
  .boost-table .row.header {
    background: rgba(0, 0, 0, 0.15);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .projection-bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .projection-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .projection-bar .year {
    font-size: 0.75rem;
    color: var(--muted);
    width: 40px;
  }

  .projection-bar .bar {
    flex: 1;
    height: 24px;
    background: var(--surface-alt);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .projection-bar .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green), #16a34a);
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  .projection-bar .value {
    font-size: 0.75rem;
    color: var(--text);
    width: 70px;
    text-align: right;
  }

  .callout {
    margin-top: 2rem;
    padding: 1rem;
    background: var(--surface);
    border-radius: 8px;
    border-left: 3px solid var(--green);
  }

  .callout p {
    color: var(--muted);
    font-size: 0.875rem;
    margin: 0;
  }
</style>

<script>
  function formatMoney(num: number): string {
    if (num >= 1000000) {
      return '\u00a3' + (num / 1000000).toFixed(2) + 'M';
    }
    return '\u00a3' + Math.round(num).toLocaleString();
  }

  function getValue(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }

  function calculatePension() {
    const currentAge = getValue('currentAge');
    const retireAge = getValue('retireAge');
    const currentValue = getValue('currentValue');
    const monthlyContrib = getValue('monthlyContrib');
    const employerPct = getValue('employerPct');
    const growthRate = getValue('growthRate');
    const desiredIncome = getValue('desiredIncome');

    if (retireAge <= currentAge) return;

    const yearsToRetire = retireAge - currentAge;
    const monthsToRetire = yearsToRetire * 12;
    const monthlyRate = growthRate / 100 / 12;
    const annualContrib = monthlyContrib * 12;
    const employerAmount = monthlyContrib * (employerPct / 100);
    const totalMonthlyContrib = monthlyContrib + employerAmount;
    const totalAnnualContrib = totalMonthlyContrib * 12;

    let pot = currentValue;
    let totalContributions = currentValue;
    let totalEmployerContrib = 0;
    let totalGrowth = 0;

    for (let m = 0; m < monthsToRetire; m++) {
      const growth = pot * monthlyRate;
      pot += growth + totalMonthlyContrib;
      totalGrowth += growth;
      if (m % 12 === 0) {
        totalContributions += annualContrib + employerAmount * 12;
        totalEmployerContrib += employerAmount * 12;
      }
    }

    totalContributions = currentValue + (monthlyContrib * monthsToRetire) + (employerAmount * monthsToRetire);
    totalEmployerContrib = employerAmount * monthsToRetire;
    const yourContributions = currentValue + (monthlyContrib * monthsToRetire);
    totalGrowth = pot - currentValue - (totalMonthlyContrib * monthsToRetire);

    const safeWithdrawal = pot * 0.04;
    const monthlyIncome = safeWithdrawal / 12;
    const yearsOfIncome = desiredIncome > 0 ? pot / desiredIncome : 0;
    const shortfall = monthlyIncome * 12 - desiredIncome;

    document.getElementById('projectedPot')!.textContent = formatMoney(pot);
    document.getElementById('potDetail')!.textContent = 'At age ' + retireAge;

    document.getElementById('monthlyIncome')!.textContent = formatMoney(monthlyIncome) + '/mo';
    document.getElementById('incomeDetail')!.textContent = formatMoney(safeWithdrawal) + '/year (4% rule)';

    document.getElementById('yearsIncome')!.textContent = yearsOfIncome.toFixed(1);
    document.getElementById('yearsDetail')!.textContent = 'At £' + Math.round(desiredIncome).toLocaleString() + '/year';

    const shortfallCard = document.getElementById('shortfallCard')!;
    const shortfallValue = document.getElementById('shortfallValue')!;
    const shortfallLabel = document.getElementById('shortfallLabel')!;
    const shortfallDetail = document.getElementById('shortfallDetail')!;

    shortfallCard.className = 'result-card ' + (shortfall >= 0 ? 'green' : 'red');
    shortfallValue.textContent = (shortfall >= 0 ? '+' : '') + formatMoney(shortfall) + '/yr';
    shortfallLabel.textContent = shortfall >= 0 ? 'Annual Surplus' : 'Annual Shortfall';
    shortfallDetail.textContent = shortfall >= 0 ? 'Above your desired income' : 'Below your desired income';

    const breakdownBar = document.getElementById('breakdownBar')!;
    const breakdownLegend = document.getElementById('breakdownLegend')!;
    const total = Math.max(pot, 1);
    const pctCurrent = (currentValue / total) * 100;
    const pctContrib = ((monthlyContrib * monthsToRetire) / total) * 100;
    const pctEmployer = ((employerAmount * monthsToRetire) / total) * 100;
    const pctGrowth = Math.max(0, 100 - pctCurrent - pctContrib - pctEmployer);

    breakdownBar.innerHTML = `
      <div class="segment seg-current" style="width: ${pctCurrent}%" title="Current Value: ${formatMoney(currentValue)}"></div>
      <div class="segment seg-contrib" style="width: ${pctContrib}%" title="Your Contributions: ${formatMoney(monthlyContrib * monthsToRetire)}"></div>
      <div class="segment seg-contrib" style="width: ${pctEmployer}%; opacity: 0.6" title="Employer Contributions: ${formatMoney(employerAmount * monthsToRetire)}"></div>
      <div class="segment seg-growth" style="width: ${pctGrowth}%" title="Investment Growth: ${formatMoney(totalGrowth)}"></div>
    `;

    breakdownLegend.innerHTML = `
      <div class="legend-item"><div class="legend-dot" style="background: var(--blue)"></div>Current: ${formatMoney(currentValue)}</div>
      <div class="legend-item"><div class="legend-dot" style="background: var(--green)"></div>Your Contribs: ${formatMoney(monthlyContrib * monthsToRetire)}</div>
      <div class="legend-item"><div class="legend-dot" style="background: var(--green); opacity: 0.6"></div>Employer: ${formatMoney(employerAmount * monthsToRetire)}</div>
      <div class="legend-item"><div class="legend-dot" style="background: var(--purple)"></div>Growth: ${formatMoney(totalGrowth)}</div>
    `;

    // Without employer matching
    let potNoEmployer = currentValue;
    for (let m = 0; m < monthsToRetire; m++) {
      potNoEmployer = potNoEmployer * (1 + monthlyRate) + monthlyContrib;
    }
    const incomeNoEmployer = (potNoEmployer * 0.04) / 12;
    const diff = pot - potNoEmployer;

    const compTable = document.getElementById('comparisonTable')!;
    compTable.innerHTML = `
      <div class="row header"><span>Scenario</span><span>Pension Pot</span><span>Monthly Income</span></div>
      <div class="row"><span class="label">Without Employer Matching</span><span class="value">${formatMoney(potNoEmployer)}</span><span class="value">${formatMoney(incomeNoEmployer)}/mo</span></div>
      <div class="row"><span class="label">With Employer Matching</span><span class="value positive">${formatMoney(pot)}</span><span class="value positive">${formatMoney(monthlyIncome)}/mo</span></div>
      <div class="row"><span class="label">Employer Match Benefit</span><span class="value positive">+${formatMoney(diff)}</span><span class="value positive">+${formatMoney(monthlyIncome - incomeNoEmployer)}/mo</span></div>
    `;

    // Impact of +£50/month
    const boostMonthly = monthlyContrib + 50;
    let potBoosted = currentValue;
    const boostedTotalMonthly = boostMonthly + employerAmount;
    for (let m = 0; m < monthsToRetire; m++) {
      potBoosted = potBoosted * (1 + monthlyRate) + boostedTotalMonthly;
    }
    const incomeBoosted = (potBoosted * 0.04) / 12;
    const boostDiff = potBoosted - pot;

    const boostTbl = document.getElementById('boostTable')!;
    boostTbl.innerHTML = `
      <div class="row header"><span>Metric</span><span>Current</span><span>With +£50/mo</span><span>Difference</span></div>
      <div class="row"><span class="label">Monthly Contribution</span><span class="value">\u00a3${Math.round(monthlyContrib)}</span><span class="value">\u00a3${Math.round(boostMonthly)}</span><span class="value positive">+\u00a350</span></div>
      <div class="row"><span class="label">Pension Pot at Retirement</span><span class="value">${formatMoney(pot)}</span><span class="value">${formatMoney(potBoosted)}</span><span class="value positive">+${formatMoney(boostDiff)}</span></div>
      <div class="row"><span class="label">Monthly Retirement Income</span><span class="value">${formatMoney(monthlyIncome)}</span><span class="value">${formatMoney(incomeBoosted)}</span><span class="value positive">+${formatMoney(incomeBoosted - monthlyIncome)}/mo</span></div>
    `;

    // Projection bars
    const barsContainer = document.getElementById('projectionBars')!;
    barsContainer.innerHTML = '';

    const milestones = [1, 3, 5, 10, 15, 20, yearsToRetire].filter((v, i, a) => a.indexOf(v) === i && v <= yearsToRetire + 2);

    let p = currentValue;
    const maxPot = Math.max(pot, 1);

    for (let y = 1; y <= Math.max(...milestones) + 1; y++) {
      for (let m = 0; m < 12; m++) {
        p = p * (1 + monthlyRate) + totalMonthlyContrib;
      }
      if (milestones.includes(y)) {
        const pct = Math.min((p / maxPot) * 100, 100);
        const bar = document.createElement('div');
        bar.className = 'projection-bar';
        bar.innerHTML = `
          <span class="year">Yr ${y}</span>
          <div class="bar"><div class="bar-fill" style="width: ${pct}%"></div></div>
          <span class="value">${formatMoney(p)}</span>
        `;
        barsContainer.appendChild(bar);
      }
    }

    // Save to localStorage
    try {
      localStorage.setItem('pensionCalc', JSON.stringify({
        currentAge, retireAge, currentValue, monthlyContrib,
        employerPct, growthRate, desiredIncome
      }));
    } catch (e) {}
  }

  function loadFromStorage() {
    try {
      const saved = localStorage.getItem('pensionCalc');
      if (saved) {
        const data = JSON.parse(saved);
        if (data.currentAge) (document.getElementById('currentAge') as HTMLInputElement).value = data.currentAge;
        if (data.retireAge) (document.getElementById('retireAge') as HTMLInputElement).value = data.retireAge;
        if (data.currentValue !== undefined) (document.getElementById('currentValue') as HTMLInputElement).value = data.currentValue;
        if (data.monthlyContrib) (document.getElementById('monthlyContrib') as HTMLInputElement).value = data.monthlyContrib;
        if (data.employerPct !== undefined) (document.getElementById('employerPct') as HTMLInputElement).value = data.employerPct;
        if (data.growthRate) (document.getElementById('growthRate') as HTMLInputElement).value = data.growthRate;
        if (data.desiredIncome) (document.getElementById('desiredIncome') as HTMLInputElement).value = data.desiredIncome;
      }
    } catch (e) {}
  }

  loadFromStorage();
  calculatePension();

  document.getElementById('calculate')!.addEventListener('click', calculatePension);
  document.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', calculatePension);
  });
</script>
