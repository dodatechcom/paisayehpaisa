---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Retirement Readiness Quiz — Are You on Track?" description="Take this free 10-question quiz to find out if you're on track for retirement. Get personalized recommendations based on your answers.">
  <div class="tool-container">
    <div class="tool-header">
      <h1>Retirement Readiness Quiz</h1>
      <p class="subtitle">Answer 10 questions to find out if you're on track for retirement</p>
    </div>

    <div class="quiz-container" id="quizContainer">
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <div class="progress-text" id="progressText">Question 1 of 10</div>

      <div id="questionsContainer"></div>

      <div class="nav-buttons">
        <button id="prevBtn" class="btn-secondary" disabled>Previous</button>
        <button id="nextBtn" class="btn-primary">Next</button>
      </div>
    </div>

    <div class="results-container" id="resultsContainer" style="display: none;">
      <div class="score-card">
        <div class="score-label">Your Retirement Score</div>
        <div class="score-value" id="scoreValue">0</div>
        <div class="score-max">out of 100</div>
        <div class="score-rating" id="scoreRating">Calculating...</div>
      </div>

      <div class="results-breakdown" id="resultsBreakdown"></div>

      <div class="recommendations" id="recommendations">
        <h3>Your Personalized Recommendations</h3>
        <div id="recList"></div>
      </div>

      <button id="retakeBtn" class="btn-primary" style="margin-top: 1.5rem;">Retake Quiz</button>
    </div>
  </div>
</BaseLayout>

<style>
  .tool-container {
    max-width: 700px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .tool-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .tool-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #94a3b8;
    font-size: 1rem;
  }

  .quiz-container {
    background: #1e293b;
    border-radius: 12px;
    padding: 2rem;
  }

  .progress-bar {
    width: 100%;
    height: 8px;
    background: #1a1d23;
    border-radius: 4px;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #22c55e, #16a34a);
    border-radius: 4px;
    transition: width 0.3s ease;
    width: 10%;
  }

  .progress-text {
    font-size: 0.8rem;
    color: #94a3b8;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .question {
    display: none;
  }

  .question.active {
    display: block;
  }

  .question h3 {
    font-size: 1.1rem;
    color: #e2e8f0;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .question-number {
    color: #22c55e;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .option {
    padding: 0.875rem 1rem;
    background: #1a1d23;
    border: 1px solid #334155;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    color: #e2e8f0;
    font-size: 0.9rem;
  }

  .option:hover {
    border-color: #22c55e;
    background: rgba(34, 197, 94, 0.05);
  }

  .option.selected {
    border-color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
  }

  .btn-primary {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
  }

  .btn-secondary {
    padding: 0.75rem 1.5rem;
    background: #334155;
    color: #e2e8f0;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .btn-secondary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .results-container {
    background: #1e293b;
    border-radius: 12px;
    padding: 2rem;
  }

  .score-card {
    text-align: center;
    padding: 2rem;
    background: #1a1d23;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .score-label {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }

  .score-value {
    font-size: 4rem;
    font-weight: 700;
    color: #22c55e;
    line-height: 1;
  }

  .score-max {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }

  .score-rating {
    font-size: 1.2rem;
    font-weight: 600;
    color: #f59e0b;
  }

  .results-breakdown {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 500px) {
    .results-breakdown {
      grid-template-columns: 1fr;
    }
  }

  .result-item {
    padding: 0.75rem;
    background: #1a1d23;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .result-item .q {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .result-item .a {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .result-item .a.good { color: #22c55e; }
  .result-item .a.ok { color: #f59e0b; }
  .result-item .a.bad { color: #ef4444; }

  .recommendations {
    background: #1a1d23;
    border-radius: 8px;
    padding: 1.25rem;
  }

  .recommendations h3 {
    font-size: 1rem;
    color: #e2e8f0;
    margin-bottom: 1rem;
  }

  .rec-item {
    padding: 0.75rem;
    background: #1e293b;
    border-radius: 6px;
    margin-bottom: 0.5rem;
    border-left: 3px solid #22c55e;
  }

  .rec-item:last-child {
    margin-bottom: 0;
  }

  .rec-item strong {
    color: #22c55e;
    font-size: 0.85rem;
  }

  .rec-item p {
    color: #94a3b8;
    font-size: 0.8rem;
    margin: 0.25rem 0 0;
  }
</style>

<script>
  const questions = [
    {
      q: "How old are you?",
      options: ["Under 25", "25-34", "35-44", "45-54", "55+"],
      points: [10, 9, 7, 5, 3]
    },
    {
      q: "What percentage of your income do you save/invest?",
      options: ["0% (I don't save)", "1-10%", "11-20%", "21-30%", "30%+"],
      points: [0, 3, 6, 8, 10]
    },
    {
      q: "How much do you have saved for retirement?",
      options: ["Nothing yet", "Under $25K", "$25K-$100K", "$100K-$500K", "$500K+"],
      points: [0, 2, 5, 8, 10]
    },
    {
      q: "Do you have an emergency fund (3-6 months of expenses)?",
      options: ["No emergency fund", "Less than 1 month", "1-3 months", "3-6 months", "6+ months"],
      points: [0, 2, 4, 7, 10]
    },
    {
      q: "Do you contribute to a 401(k) or IRA?",
      options: ["No", "Yes, but not enough for employer match", "Yes, getting full employer match", "Yes, maxing it out", "Yes, maxing both 401(k) and IRA"],
      points: [0, 3, 6, 8, 10]
    },
    {
      q: "How much high-interest debt do you have (credit cards, personal loans)?",
      options: ["Over $20K", "$10K-$20K", "$5K-$10K", "$1K-$5K", "None"],
      points: [0, 2, 4, 7, 10]
    },
    {
      q: "When do you plan to retire?",
      options: ["Already retired", "55-59", "60-64", "65-69", "70+"],
      points: [3, 8, 10, 7, 5]
    },
    {
      q: "How would you describe your investment knowledge?",
      options: ["Complete beginner", "Basic (savings accounts)", "Intermediate (index funds)", "Advanced (diversified portfolio)", "Expert (active trading)"],
      points: [2, 4, 7, 9, 10]
    },
    {
      q: "Do you have life insurance?",
      options: ["No, and I don't need it", "No, but I probably should", "Yes, basic employer coverage", "Yes, term life policy", "Yes, comprehensive coverage"],
      points: [1, 3, 5, 8, 10]
    },
    {
      q: "How often do you review your financial plan?",
      options: ["Never", "Once a year", "Every few months", "Monthly", "Weekly"],
      points: [1, 4, 7, 9, 10]
    }
  ];

  let currentQ = 0;
  let answers: number[] = new Array(questions.length).fill(-1);

  function renderQuestion() {
    const container = document.getElementById('questionsContainer')!;
    container.innerHTML = '';

    const q = questions[currentQ];
    const div = document.createElement('div');
    div.className = 'question active';
    div.innerHTML = `
      <div class="question-number">Question ${currentQ + 1} of ${questions.length}</div>
      <h3>${q.q}</h3>
      <div class="options">
        ${q.options.map((opt, i) => `
          <div class="option ${answers[currentQ] === i ? 'selected' : ''}" data-index="${i}">
            ${opt}
          </div>
        `).join('')}
      </div>
    `;
    container.appendChild(div);

    div.querySelectorAll('.option').forEach(opt => {
      opt.addEventListener('click', () => {
        answers[currentQ] = parseInt(opt.dataset.index || '0');
        div.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
      });
    });

    document.getElementById('progressFill')!.style.width = ((currentQ + 1) / questions.length * 100) + '%';
    document.getElementById('progressText')!.textContent = `Question ${currentQ + 1} of ${questions.length}`;

    (document.getElementById('prevBtn') as HTMLButtonElement).disabled = currentQ === 0;
    document.getElementById('nextBtn')!.textContent = currentQ === questions.length - 1 ? 'See Results' : 'Next';
  }

  function showResults() {
    let totalScore = 0;
    let maxScore = questions.length * 10;

    answers.forEach((a, i) => {
      if (a >= 0) {
        totalScore += questions[i].points[a];
      }
    });

    const pct = Math.round((totalScore / maxScore) * 100);

    document.getElementById('quizContainer')!.style.display = 'none';
    document.getElementById('resultsContainer')!.style.display = 'block';

    document.getElementById('scoreValue')!.textContent = pct.toString();

    let rating = '';
    let color = '';
    if (pct >= 80) { rating = 'Excellent — You\'re on track!'; color = '#22c55e'; }
    else if (pct >= 60) { rating = 'Good — Room for improvement'; color = '#f59e0b'; }
    else if (pct >= 40) { rating = 'Fair — Action needed'; color = '#f97316'; }
    else { rating = 'Needs Work — Start now'; color = '#ef4444'; }

    const scoreEl = document.getElementById('scoreValue')!;
    scoreEl.style.color = color;
    document.getElementById('scoreRating')!.textContent = rating;
    document.getElementById('scoreRating')!.style.color = color;

    // Breakdown
    const breakdown = document.getElementById('resultsBreakdown')!;
    breakdown.innerHTML = '';
    answers.forEach((a, i) => {
      const item = document.createElement('div');
      item.className = 'result-item';
      const score = a >= 0 ? questions[i].points[a] : 0;
      const cls = score >= 7 ? 'good' : score >= 4 ? 'ok' : 'bad';
      item.innerHTML = `
        <span class="q">Q${i + 1}</span>
        <span class="a ${cls}">${a >= 0 ? questions[i].options[a] : 'Skipped'} (${score}/10)</span>
      `;
      breakdown.appendChild(item);
    });

    // Recommendations
    const recList = document.getElementById('recList')!;
    recList.innerHTML = '';

    const recs = [];
    if (answers[1] < 2) recs.push({ title: 'Increase Savings Rate', desc: 'Aim for at least 15-20% of income. Set up automatic transfers on payday.' });
    if (answers[2] < 3) recs.push({ title: 'Build Retirement Savings', desc: 'Open a Roth IRA and invest in low-cost index funds like VTI or VOO.' });
    if (answers[3] < 3) recs.push({ title: 'Build Emergency Fund', desc: 'Save 3-6 months of expenses in a high-yield savings account before investing heavily.' });
    if (answers[4] < 2) recs.push({ title: 'Maximize Employer Match', desc: 'At minimum, contribute enough to get your full employer 401(k) match — it\'s free money.' });
    if (answers[5] < 3) recs.push({ title: 'Pay Off High-Interest Debt', desc: 'Credit card debt at 20%+ APR destroys wealth. Pay this off before investing.' });
    if (answers[7] < 3) recs.push({ title: 'Learn Investing Basics', desc: 'Read "The Simple Path to Wealth" by JL Collins or "The Bogleheads Guide to Investing."' });

    if (recs.length === 0) {
      recs.push({ title: 'Keep It Up!', desc: 'Your financial habits are strong. Stay consistent and review your plan annually.' });
    }

    recs.forEach(r => {
      const div = document.createElement('div');
      div.className = 'rec-item';
      div.innerHTML = `<strong>${r.title}</strong><p>${r.desc}</p>`;
      recList.appendChild(div);
    });
  }

  document.getElementById('nextBtn')!.addEventListener('click', () => {
    if (currentQ < questions.length - 1) {
      currentQ++;
      renderQuestion();
    } else {
      showResults();
    }
  });

  document.getElementById('prevBtn')!.addEventListener('click', () => {
    if (currentQ > 0) {
      currentQ--;
      renderQuestion();
    }
  });

  document.getElementById('retakeBtn')!.addEventListener('click', () => {
    currentQ = 0;
    answers = new Array(questions.length).fill(-1);
    document.getElementById('quizContainer')!.style.display = 'block';
    document.getElementById('resultsContainer')!.style.display = 'none';
    renderQuestion();
  });

  renderQuestion();
</script>
