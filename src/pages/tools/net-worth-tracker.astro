---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Net Worth Tracker — Calculate Your Total Wealth" description="Track your assets and liabilities to calculate your net worth. See your wealth grow over time with this free interactive tool.">
  <div class="tool-container">
    <div class="tool-header">
      <h1>Net Worth Tracker</h1>
      <p class="subtitle">Calculate your total wealth — assets minus liabilities</p>
    </div>

    <div class="tracker-grid">
      <div class="section assets-section">
        <h2>Assets (What You Own)</h2>

        <div class="category">
          <h3>Cash &amp; Savings</h3>
          <div class="input-row">
            <label>Checking Account</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="cash" value="5000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Savings Account</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="cash" value="15000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Emergency Fund</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="cash" value="10000" min="0"></div>
          </div>
        </div>

        <div class="category">
          <h3>Investments</h3>
          <div class="input-row">
            <label>401(k) / IRA</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="investments" value="50000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Brokerage Account</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="investments" value="30000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Crypto Holdings</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="investments" value="5000" min="0"></div>
          </div>
        </div>

        <div class="category">
          <h3>Property</h3>
          <div class="input-row">
            <label>Home Value</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="property" value="350000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Other Property</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="property" value="0" min="0"></div>
          </div>
        </div>

        <div class="category">
          <h3>Other Assets</h3>
          <div class="input-row">
            <label>Cars / Vehicles</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="other" value="20000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Other Valuables</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="asset" data-category="other" value="5000" min="0"></div>
          </div>
        </div>

        <div class="total-bar asset-total">
          <span>Total Assets</span>
          <span id="totalAssets">$490,000</span>
        </div>
      </div>

      <div class="section liabilities-section">
        <h2>Liabilities (What You Owe)</h2>

        <div class="category">
          <h3>Mortgage &amp; Property</h3>
          <div class="input-row">
            <label>Mortgage Balance</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="mortgage" value="250000" min="0"></div>
          </div>
          <div class="input-row">
            <label>HELOC</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="mortgage" value="0" min="0"></div>
          </div>
        </div>

        <div class="category">
          <h3>Loans</h3>
          <div class="input-row">
            <label>Auto Loan</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="loans" value="15000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Student Loans</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="loans" value="20000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Personal Loan</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="loans" value="0" min="0"></div>
          </div>
        </div>

        <div class="category">
          <h3>Credit Cards</h3>
          <div class="input-row">
            <label>Card 1 Balance</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="credit" value="3000" min="0"></div>
          </div>
          <div class="input-row">
            <label>Card 2 Balance</label>
            <div class="input-wrapper"><span class="currency">$</span><input type="number" class="liability" data-category="credit" value="1500" min="0"></div>
          </div>
        </div>

        <div class="total-bar liability-total">
          <span>Total Liabilities</span>
          <span id="totalLiabilities">$289,500</span>
        </div>
      </div>
    </div>

    <div class="net-worth-display">
      <div class="net-worth-card">
        <div class="net-worth-label">Your Net Worth</div>
        <div class="net-worth-value" id="netWorth">$200,500</div>
        <div class="net-worth-detail" id="netWorthDetail">Assets ($490,000) - Liabilities ($289,500)</div>
      </div>

      <div class="breakdown-grid">
        <div class="breakdown-card">
          <div class="breakdown-label">Cash &amp; Savings</div>
          <div class="breakdown-value" id="cashTotal">$30,000</div>
        </div>
        <div class="breakdown-card">
          <div class="breakdown-label">Investments</div>
          <div class="breakdown-value" id="investmentsTotal">$85,000</div>
        </div>
        <div class="breakdown-card">
          <div class="breakdown-label">Property</div>
          <div class="breakdown-value" id="propertyTotal">$350,000</div>
        </div>
        <div class="breakdown-card">
          <div class="breakdown-label">Debt-to-Asset</div>
          <div class="breakdown-value" id="debtToAsset">59%</div>
        </div>
      </div>
    </div>

    <div class="callout">
      <p><strong>Tip:</strong> Track your net worth monthly. Aim to increase it by 10-20% per year. The fastest way to grow net worth: increase savings rate and pay down high-interest debt.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .tool-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .tool-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .tool-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #94a3b8;
    font-size: 1rem;
  }

  .tracker-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .tracker-grid {
      grid-template-columns: 1fr;
    }
  }

  .section {
    background: #1e293b;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .section h2 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: #e2e8f0;
  }

  .category {
    margin-bottom: 1.25rem;
  }

  .category h3 {
    font-size: 0.8rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .input-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .input-row label {
    font-size: 0.875rem;
    color: #cbd5e1;
    flex-shrink: 0;
    width: 140px;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    background: #1a1d23;
    border: 1px solid #334155;
    border-radius: 6px;
    flex: 1;
    max-width: 180px;
  }

  .currency {
    padding: 0 0.5rem;
    color: #22c55e;
    font-weight: 600;
    font-size: 0.8rem;
  }

  input[type="number"] {
    flex: 1;
    background: transparent;
    border: none;
    color: #e2e8f0;
    padding: 0.5rem;
    font-size: 0.875rem;
    font-family: inherit;
    width: 100%;
  }

  input[type="number"]:focus {
    outline: none;
  }

  .total-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .asset-total {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .asset-total span:last-child {
    color: #22c55e;
    font-size: 1.1rem;
  }

  .liability-total {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .liability-total span:last-child {
    color: #ef4444;
    font-size: 1.1rem;
  }

  .net-worth-display {
    background: #1e293b;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .net-worth-card {
    text-align: center;
    padding: 1.5rem;
    background: #1a1d23;
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .net-worth-label {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }

  .net-worth-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: #22c55e;
    margin-bottom: 0.25rem;
  }

  .net-worth-detail {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 600px) {
    .breakdown-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .breakdown-card {
    text-align: center;
    padding: 0.75rem;
    background: #1a1d23;
    border-radius: 8px;
  }

  .breakdown-label {
    font-size: 0.7rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .breakdown-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: #e2e8f0;
  }

  .callout {
    padding: 1rem;
    background: #1e293b;
    border-radius: 8px;
    border-left: 3px solid #22c55e;
  }

  .callout p {
    color: #94a3b8;
    font-size: 0.875rem;
    margin: 0;
  }
</style>

<script>
  function formatMoney(num: number): string {
    if (num >= 0) {
      return '$' + num.toLocaleString();
    }
    return '-$' + Math.abs(num).toLocaleString();
  }

  function calculate() {
    const assets = document.querySelectorAll('.asset') as NodeListOf<HTMLInputElement>;
    const liabilities = document.querySelectorAll('.liability') as NodeListOf<HTMLInputElement>;

    let totalAssets = 0;
    let totalLiabilities = 0;

    const categoryTotals: Record<string, number> = {
      cash: 0,
      investments: 0,
      property: 0,
      other: 0,
      mortgage: 0,
      loans: 0,
      credit: 0,
    };

    assets.forEach(input => {
      const val = parseFloat(input.value) || 0;
      const cat = input.dataset.category || 'other';
      categoryTotals[cat] += val;
      totalAssets += val;
    });

    liabilities.forEach(input => {
      const val = parseFloat(input.value) || 0;
      const cat = input.dataset.category || 'other';
      categoryTotals[cat] += val;
      totalLiabilities += val;
    });

    const netWorth = totalAssets - totalLiabilities;
    const debtToAsset = totalAssets > 0 ? ((totalLiabilities / totalAssets) * 100).toFixed(0) : '0';

    document.getElementById('totalAssets')!.textContent = formatMoney(totalAssets);
    document.getElementById('totalLiabilities')!.textContent = formatMoney(totalLiabilities);
    document.getElementById('netWorth')!.textContent = formatMoney(netWorth);
    document.getElementById('netWorthDetail')!.textContent = `Assets (${formatMoney(totalAssets)}) - Liabilities (${formatMoney(totalLiabilities)})`;

    document.getElementById('cashTotal')!.textContent = formatMoney(categoryTotals.cash);
    document.getElementById('investmentsTotal')!.textContent = formatMoney(categoryTotals.investments);
    document.getElementById('propertyTotal')!.textContent = formatMoney(categoryTotals.property);
    document.getElementById('debtToAsset')!.textContent = debtToAsset + '%';

    const nwEl = document.getElementById('netWorth')!;
    nwEl.style.color = netWorth >= 0 ? '#22c55e' : '#ef4444';
  }

  document.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', calculate);
  });

  calculate();
</script>
