---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const basics = await getCollection('crypto-basics');
const safe = await getCollection('safe-crypto');
const scam = await getCollection('crypto-scam');
const answers = await getCollection('crypto-answers');
const tax = await getCollection('crypto-tax');
const tools = await getCollection('crypto-tools');

const all = [...basics, ...safe, ...scam, ...answers, ...tax, ...tools]
  .filter(a => !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recent = all.slice(0, 5);

const categories = [
  { slug: 'crypto-basics', name: 'Crypto Basics', icon: '📘', desc: 'Buying, wallets, exchanges, DCA' },
  { slug: 'safe-crypto', name: 'Safe Crypto', icon: '🔒', desc: 'Seed phrases, 2FA, hardware wallets' },
  { slug: 'crypto-scam', name: 'Crypto Scam', icon: '⚠️', desc: 'Spot scams, phishing, fake wallets' },
  { slug: 'crypto-answers', name: 'Crypto Answers', icon: '💬', desc: 'Daily Q&A from BitcoinTalk' },
  { slug: 'crypto-tax', name: 'Crypto Tax', icon: '💰', desc: 'Country guides, reporting gains' },
  { slug: 'crypto-tools', name: 'Crypto Tools', icon: '🛠️', desc: 'Calculators, checkers, wizards' },
];
---

<BaseLayout title="PaisayehPaisa" description="Crypto in plain language. Learn about Bitcoin, wallets, security, scams, and taxes — sourced from BitcoinTalk.">
  <div class="hero">
    <h1>Crypto in plain language.</h1>
    <p>Answers to the questions BitcoinTalk users ask every day — in one place, simple and clear.</p>
  </div>

  <div class="cat-grid">
    {categories.map(cat => (
      <a href={`/${cat.slug}/`} class="cat-card">
        <div class="icon">{cat.icon}</div>
        <h3>{cat.name}</h3>
        <p>{cat.desc}</p>
      </a>
    ))}
  </div>

  <h2 style="margin-bottom:1rem;">Recent Articles</h2>
  <ul class="article-list">
    {recent.map(a => (
      <li>
        <a href={`/${a.data.categories[0]}/${a.slug}/`}>{a.data.title}</a>
        <div class="desc">{a.data.description}</div>
        <div class="article-meta" style="margin-top:0.25rem;">
          {a.data.date.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
