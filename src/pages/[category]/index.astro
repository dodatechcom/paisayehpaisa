---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { getTagStyle } from '../../utils/tagStyles';

export async function getStaticPaths() {
  const categories = ['crypto-basics', 'safe-crypto', 'crypto-scam', 'crypto-answers', 'crypto-tax', 'crypto-tools', 'trading', 'insurance', 'investing', 'blog', 'personal-finance'];
  return categories.map(cat => ({
    params: { category: cat },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const collection = await getCollection(category as any);
const articles = collection.filter(a => !a.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryConfig: Record<string, { name: string; icon: string; desc: string }> = {
  'crypto-basics': { name: 'Crypto Basics', icon: '📘', desc: 'Buying, wallets, exchanges, DCA' },
  'safe-crypto': { name: 'Safe Crypto', icon: '🔒', desc: 'Seed phrases, 2FA, hardware wallets' },
  'crypto-scam': { name: 'Crypto Scam', icon: '⚠️', desc: 'Spot scams, phishing, fake wallets' },
  'crypto-answers': { name: 'Crypto Answers', icon: '💬', desc: 'Daily Q&A from BitcoinTalk' },
  'crypto-tax': { name: 'Crypto Tax', icon: '💰', desc: 'Country guides, reporting gains' },
  'crypto-tools': { name: 'Crypto Tools', icon: '🛠️', desc: 'Calculators, checkers, wizards' },
  'trading': { name: 'Trading', icon: '📊', desc: 'Technical analysis, risk management, psychology' },
  'insurance': { name: 'Insurance', icon: '🛡️', desc: 'Life, health, auto, and home insurance explained' },
  'investing': { name: 'Investing', icon: '📈', desc: 'Beginner guides, ETF comparisons, portfolio strategies' },
  'blog': { name: 'Market Blog', icon: '📰', desc: 'Latest market updates and investment insights' },
  'personal-finance': { name: 'Personal Finance', icon: '💳', desc: 'Credit cards, loans, banking, mortgages, and budgeting' },
};

const cfg = categoryConfig[category];
---

<BaseLayout title={cfg.name} description={cfg.desc}>
  <Breadcrumbs category={category} categoryNames={Object.fromEntries(Object.entries(categoryConfig).map(([k,v]) => [k, v.name]))} />

  <div class="cat-header">
    <span class="icon">{cfg.icon}</span>
    <h1>{cfg.name}</h1>
    <span class="badge">{articles.length} articles</span>
  </div>
  <p style="color:var(--muted); margin-bottom:2rem;">{cfg.desc}</p>

  <ul class="article-list">
    {articles.map(a => (
      <li>
        <a href={`/${category}/${a.slug}/`}>{a.data.title}</a>
        <div class="desc">{a.data.description}</div>
        <div class="article-meta" style="margin-top:0.5rem;">
          <span>{a.data.date.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</span>
          {a.data.tags?.map((t, i) => {
            const s = getTagStyle(t);
            return <>{i > 0 && ' '}<span style={`background:${s.bg};color:${s.color};font-size:0.78rem;padding:0.2rem 0.6rem;border-radius:999px;font-weight:500;display:inline-flex;align-items:center;gap:0.25rem;`}>{s.icon} {t}</span></>
          })}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
