---
export interface Props {
  category: string;
  slug?: string;
  categoryNames: Record<string, string>;
}

const { category, slug, categoryNames } = Astro.props;
---

<nav class="breadcrumbs">
  <a href="/">Home</a>
  {slug ? (
    <>
      <span> / </span>
      <a href={`/${category}/`}>{categoryNames[category] || category}</a>
      <span> / </span>
      <span>{slug}</span>
    </>
  ) : (
    <>
      <span> / </span>
      <span>{categoryNames[category] || category}</span>
    </>
  )}
</nav>
