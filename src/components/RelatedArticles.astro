  'crypto-basics': '#2563eb',
  'safe-crypto': '#059669',
  'crypto-scam': '#dc2626',
  'crypto-answers': '#7c3aed',
  'crypto-tax': '#d97706',
  'trading': '#f97316',
  'insurance': '#6366f1',
  'investing': '#10b981',
  'blog': '#8b5cf6',
  'personal-finance': '#0ea5e9',
