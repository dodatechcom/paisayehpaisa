  'doji-candlestick-pattern': { title: 'Doji Candlestick Pattern', description: 'Market indecision signal', category: 'trading' },
  'hammer-shooting-star': { title: 'Hammer & Shooting Star', description: 'Reversal patterns explained', category: 'trading' },
